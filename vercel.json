{
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/today", "destination": "/morning-briefing-koda.html" },
    { "source": "/reviews", "destination": "/reviews/index.html" },
    { "source": "/reviews/", "destination": "/reviews/index.html" },
    { "source": "/dojo", "destination": "/dojo/index.html" },
    { "source": "/dojo/", "destination": "/dojo/index.html" },
    { "source": "/dojo/claude-code", "destination": "/dojo/claude-code/index.html" },
    { "source": "/dojo/claude-code/", "destination": "/dojo/claude-code/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/(manifest|search-index)\\.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    }
  ]
}
